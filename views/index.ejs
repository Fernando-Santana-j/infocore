                    </div>
                    <div class="contact-item fade-in">
                        <div class="contact-icon">📞</div>
                        <div>
                            <h3>Telefone</h3>
                            <p>(79) 99134-3921</p>
                        </div>
                    </div>
                    <div class="contact-item fade-in">
                        <div class="contact-icon">✉️</div>
                        <div>
